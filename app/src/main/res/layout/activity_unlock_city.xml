<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Google Map -->

    <!-- Fixed pin image in center -->
    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <ImageView
        android:id="@+id/fixed_pin"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:src="@drawable/ic_map_pin" /> <!-- Replace with your pin drawable -->

    <!-- Clue TextView at the top -->
    <TextView
        android:id="@+id/clueText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#88000000"
        android:padding="12dp"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:text="City clue will appear here"
        android:layout_gravity="top" />

    <!-- Submit Guess button at the bottom center -->
    <Button
        android:id="@+id/submitGuessBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Submit Guess"
        android:layout_gravity="bottom|center"
        android:layout_margin="16dp" />
</FrameLayout>
