<?xml version="1.0" encoding="utf-8"?>
<!-- פריסה עבור מסך המעבר לאחר תשובה נכונה בשלב 7 -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".CorrectScreen7">

    <!-- תמונת רקע עבור מסך "תשובה נכונה" של שלב 7 -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/correct_screen7"
        android:scaleType="fitCenter" />

    <!-- מיכל לסידור התוכן בצורה אנכית מעל הרקע -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- תצוגת טקסט המציגה את טבלת המובילים עבור שלב זה -->
        <TextView
            android:id="@+id/leaderboardText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="50dp"
            android:background="#80000000"
            android:padding="16dp"
            android:text="Loading Leaderboard..."
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- מרווח גמיש לדחיפת הכפתור לתחתית -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical" />

        <!-- כפתור לאישור ומעבר לשלב הבא -->
        <Button
            android:id="@+id/BtClick20"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Nice quoting!!"
            android:textAllCaps="false"
            android:textSize="35sp" />

    </LinearLayout>
</FrameLayout>