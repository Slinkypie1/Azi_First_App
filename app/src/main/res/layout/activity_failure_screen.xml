<?xml version="1.0" encoding="utf-8"?>
<!-- פריסה עבור מסך הכישלון (You Lose) -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main3"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".Failure">

    <!-- תמונת רקע המציינת הפסד -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/you_lose"
        android:scaleType="fitCenter" />

    <!-- מיכל לסידור הודעת ההפסד וכפתור האתחול -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="?attr/actionBarSize">

        <!-- מרווח גמיש -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- הודעת "הפסדת" -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="You Lose"
            android:textSize="40sp"
            android:layout_gravity="center_horizontal|center_vertical"/>

        <!-- כפתור לאתחול המשחק וחזרה למסך הראשי -->
        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/BtClickLose"
            android:text="Click here to restart the quiz"
            android:layout_gravity="center_horizontal|center_vertical"
            android:textSize="40sp"/>

    </LinearLayout>
</FrameLayout>
