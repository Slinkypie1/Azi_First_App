<?xml version="1.0" encoding="utf-8"?>
<!-- פריסה עבור מסך הפתיחה (Splash Screen) המוצג בעת טעינת האפליקציה -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".SplashScreen">

    <!-- מיכל הממרכז את הלוגו ואת חיווי הטעינה -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical">

        <!-- תמונת לוגו האפליקציה -->
        <ImageView
            android:id="@+id/ivSplashLogo"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:src="@drawable/app_icon"
            android:layout_marginBottom="24dp"
            android:contentDescription="App Logo" />

        <!-- טקסט המציין שהאפליקציה בטעינה -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loading..."
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- סרגל התקדמות מעגלי (Loading Spinner) -->
        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp" />

    </LinearLayout>

</FrameLayout>
