<?xml version="1.0" encoding="utf-8"?>
<!-- פריסה עבור מסך הסיום של מצב המשחק הרגיל (Casual Finish) -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".CasualFinish">

    <!-- תמונת רקע של מזל טוב לסיום המשחק -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/congratulations"
        android:scaleType="fitCenter" />

    <!-- מיכל הממרכז את הודעת הסיום והצעות להמשך -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="20dp">

        <!-- כותרת סיום -->
        <TextView
            android:id="@+id/tvCongratulation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="You've Finished!"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginBottom="20dp"/>

        <!-- הודעת משוב על סיום כל השלבים -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Great job!\nYou've completed all of the levels"
            android:textSize="20sp"
            android:textColor="#000000"
            android:gravity="center"
            android:layout_marginBottom="24dp"/>

        <!-- הצעה לעבור למצב משחק מתוזמן לאתגר נוסף -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Want a real challenge?\nTry Timed Mode to test your speed!"
            android:textSize="18sp"
            android:textColor="#D32F2F"
            android:textStyle="italic"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <!-- כפתור למעבר למצב מתוזמן -->
        <Button
            android:id="@+id/btnTryTimedMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Try Timed Mode"
            android:textSize="16sp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#D32F2F"
            android:textColor="#FFFFFF"/>

        <!-- כפתור לחזרה לתפריט הראשי -->
        <Button
            android:id="@+id/btnBackToMenu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Back to Menu"
            android:textSize="18sp"
            android:padding="12dp"/>

    </LinearLayout>
</FrameLayout>
